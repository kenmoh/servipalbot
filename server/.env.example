APP_ENV=development
LOG_LEVEL=INFO

AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192
GROQ_BASE_URL=https://api.groq.com/openai/v1

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

WHATSAPP_TOKEN=your_whatsapp_cloud_api_token_here
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id_here
WHATSAPP_API_VERSION=v19.0
WHATSAPP_DAILY_LIMIT=250
WHATSAPP_WEBHOOK_VERIFY_TOKEN=servipal_webhook_secret

META_ACCESS_TOKEN=your_meta_page_access_token_here
FACEBOOK_PAGE_ID=your_facebook_page_id_here
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here
META_API_VERSION=v19.0
META_DAILY_POST_LIMIT=25

RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com
RESEND_FROM_ADDRESS=
RESEND_FROM_NAME=ServiPal
RESEND_REPLY_TO=
EMAIL_DAILY_LIMIT=50
EMAIL_DELAY_SECONDS=30

USE_SERPAPI=true
SERPAPI_KEY=your_serpapi_key_here

BOT_NAME=ServiPal
BOT_TIMEZONE=Africa/Lagos
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
REQUEST_TIMEOUT=30
MORNING_OUTREACH_HOUR=9
MIDDAY_SOCIAL_HOUR=12
